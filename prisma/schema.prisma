generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  username    String       @unique      // A required unique handle (e.g., @movienerd99)
  password    String                    // REQUIRED: We will store the encrypted hash here, NEVER plain text
  name        String                    // Made this required instead of optional
  birthdate   DateTime                  // Required for age verification
  avatar      String?                   // Optional profile picture URL
  bio         String?                   // Optional short bio for their public profile
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt   // Prisma automatically updates this when the user changes their profile
  savedMovies SavedMovie[] 
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
}

model SavedMovie {
  id           Int       @id @default(autoincrement())
  tmdbId       Int
  title        String
  posterPath   String?
  isFavorite   Boolean   @default(false)
  rating       Int?     
  isDownloaded Boolean   @default(false) // <--- Tracks if they downloaded it
  downloadedAt DateTime?                   // <--- Tracks exactly when they downloaded it
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())

  @@unique([userId, tmdbId]) 
}